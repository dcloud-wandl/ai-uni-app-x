import { describe, it, expect, beforeAll, afterAll } from '@uni-helper/uni-uts-test'
import { getTasks } from '@/utils/task-manager'

describe('任务管理系统自动化测试', () => {
	beforeAll(() => {
		// 清空所有任务，确保测试环境干净
		uni.setStorageSync('tasks', '[]')
	})

	afterAll(() => {
		// 测试结束后清空所有任务
		uni.setStorageSync('tasks', '[]')
	})

	it('应该能够新增、编辑和删除任务', async () => {
		// 1. 应用启动后进入首页，点击右下角的fab按钮，打开新增任务页面
		await uni.navigateTo({
			url: '/pages/task-edit/task-edit'
		})
		await uni.sleep(500)

		// 输入第一个任务
		const tomorrow = new Date()
		tomorrow.setDate(tomorrow.getDate() + 1)
		const tomorrowDate = `${tomorrow.getFullYear()}-${String(tomorrow.getMonth() + 1).padStart(2, '0')}-${String(tomorrow.getDate()).padStart(2, '0')}`

		const taskEditPage1 = getCurrentPages().pop() as any
		taskEditPage1.vm.form.title = '测试任务-01'
		taskEditPage1.vm.form.description = '任务描述 001'
		taskEditPage1.vm.form.deadline = tomorrowDate
		taskEditPage1.vm.priorityIndex = 2 // 低
		taskEditPage1.vm.form.priority = 'Low'
		await taskEditPage1.vm.submitForm()
		await uni.sleep(500)

		// 断言当前任务列表页有一条记录
		const tasks1 = getTasks()
		expect(tasks1.length).toBe(1)
		expect(tasks1[0].title).toBe('测试任务-01')

		// 2. 点击第一条任务，打开任务详情
		await uni.navigateTo({
			url: `/pages/task-detail/task-detail?id=${tasks1[0].id}`
		})
		await uni.sleep(500)

		// 在任务详情页点击编辑，打开任务的编辑页面
		const taskDetailPage1 = getCurrentPages().pop() as any
		await taskDetailPage1.vm.goToEdit()
		await uni.sleep(500)

		// 将该任务内容修改为：测试任务-01-v2, 任务描述 001-v2, 明天, 中
		const taskEditPage2 = getCurrentPages().pop() as any
		taskEditPage2.vm.form.title = '测试任务-01-v2'
		taskEditPage2.vm.form.description = '任务描述 001-v2'
		taskEditPage2.vm.form.deadline = tomorrowDate
		taskEditPage2.vm.priorityIndex = 1 // 中
		taskEditPage2.vm.form.priority = 'Medium'
		await taskEditPage2.vm.submitForm()
		await uni.sleep(500)

		// 任务编辑后自动返回任务详情页，并且任务详情页内容自动刷新，需要断言判断是否生效
		const taskDetailPage2 = getCurrentPages().pop() as any
		expect(taskDetailPage2.vm.task.title).toBe('测试任务-01-v2')
		expect(taskDetailPage2.vm.task.description).toBe('任务描述 001-v2')
		expect(taskDetailPage2.vm.task.priority).toBe('Medium')

		// 任务详情页返回任务列表页，任务列表页也会刷新，需要通过断言判断是否生效
		uni.navigateBack()
		await uni.sleep(500)
		const tasks2 = getTasks()
		expect(tasks2.length).toBe(1)
		expect(tasks2[0].title).toBe('测试任务-01-v2')

		// 3. 任务列表页，点击右下角的fab按钮，打开新增任务页面，输入第2个任务
		await uni.navigateTo({
			url: '/pages/task-edit/task-edit'
		})
		await uni.sleep(500)

		const afterTomorrow = new Date()
		afterTomorrow.setDate(afterTomorrow.getDate() + 2)
		const afterTomorrowDate = `${afterTomorrow.getFullYear()}-${String(afterTomorrow.getMonth() + 1).padStart(2, '0')}-${String(afterTomorrow.getDate()).padStart(2, '0')}`

		const taskEditPage3 = getCurrentPages().pop() as any
		taskEditPage3.vm.form.title = '测试任务-02'
		taskEditPage3.vm.form.description = '任务描述 002'
		taskEditPage3.vm.form.deadline = afterTomorrowDate
		taskEditPage3.vm.priorityIndex = 1 // 中
		taskEditPage3.vm.form.priority = 'Medium'
		await taskEditPage3.vm.submitForm()
		await uni.sleep(500)

		// 断言当前任务列表页有2条记录
		const tasks3 = getTasks()
		expect(tasks3.length).toBe(2)

		// 4. 向左滑动第2条任务，露出编辑和删除按钮，点击编辑按钮，打开第2条任务的编辑页
		// 由于没有 swiper-cell，这里模拟点击长按显示操作，然后点击编辑
		const homePage = getCurrentPages().pop() as any
		homePage.vm.toggleActions(tasks3[1].id) // 假设第二条任务是 tasks3[1]
		await uni.sleep(500)
		await homePage.vm.goToEdit(tasks3[1].id)
		await uni.sleep(500)

		// 将第二条任务内容修改如下：测试任务-02-v2, 任务描述 002-v2, 5天后, 高
		const fiveDaysLater = new Date()
		fiveDaysLater.setDate(fiveDaysLater.getDate() + 5)
		const fiveDaysLaterDate = `${fiveDaysLater.getFullYear()}-${String(fiveDaysLater.getMonth() + 1).padStart(2, '0')}-${String(fiveDaysLater.getDate()).padStart(2, '0')}`

		const taskEditPage4 = getCurrentPages().pop() as any
		taskEditPage4.vm.form.title = '测试任务-02-v2'
		taskEditPage4.vm.form.description = '任务描述 002-v2'
		taskEditPage4.vm.form.deadline = fiveDaysLaterDate
		taskEditPage4.vm.priorityIndex = 0 // 高
		taskEditPage4.vm.form.priority = 'High'
		await taskEditPage4.vm.submitForm()
		await uni.sleep(500)

		// 任务编辑后自动返回任务详情页，并且任务详情页内容自动刷新，需要断言判断是否生效
		const taskDetailPage3 = getCurrentPages().pop() as any
		expect(taskDetailPage3.vm.task.title).toBe('测试任务-02-v2')
		expect(taskDetailPage3.vm.task.description).toBe('任务描述 002-v2')
		expect(taskDetailPage3.vm.task.priority).toBe('High')

		// 任务详情页返回任务列表页，任务列表页也会刷新，需要通过断言判断是否生效
		uni.navigateBack()
		await uni.sleep(500)
		const tasks4 = getTasks()
		expect(tasks4.length).toBe(2)
		expect(tasks4[1].title).toBe('测试任务-02-v2')

		// 5. 任务列表页，点击右下角的fab按钮，打开新增任务页面，输入第3个任务
		await uni.navigateTo({
			url: '/pages/task-edit/task-edit'
		})
		await uni.sleep(500)

		const taskEditPage5 = getCurrentPages().pop() as any
		taskEditPage5.vm.form.title = '测试任务-03'
		taskEditPage5.vm.form.description = '任务描述 003'
		taskEditPage5.vm.form.deadline = afterTomorrowDate
		taskEditPage5.vm.priorityIndex = 1 // 中
		taskEditPage5.vm.form.priority = 'Medium'
		await taskEditPage5.vm.submitForm()
		await uni.sleep(500)

		// 断言当前任务列表页有3条记录
		const tasks5 = getTasks()
		expect(tasks5.length).toBe(3)

		// 6. 向左滑动第3条任务，露出编辑和删除按钮，点击删除按钮，如果有删除确认框，要确认删除，然后断言任务列表剩余 2 条记录。
		// 模拟点击长按显示操作，然后点击删除
		homePage.vm.toggleActions(tasks5[2].id) // 假设第三条任务是 tasks5[2]
		await uni.sleep(500)
		// 模拟点击删除按钮，并确认删除
		const originalConfirm = uni.showModal
		uni.showModal = (options: UniApp.ShowModalOptions) => {
			options.success && options.success({ confirm: true, cancel: false })
			return {} as UniApp.ShowModalRes
		}
		await homePage.vm.confirmDelete(tasks5[2].id)
		uni.showModal = originalConfirm // 恢复原始的 showModal
		await uni.sleep(500)

		// 断言任务列表剩余 2 条记录
		const tasks6 = getTasks()
		expect(tasks6.length).toBe(2)
	})
})
